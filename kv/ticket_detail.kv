#:import COLORS theme.COLORS

<TicketDetailScreen>:
    md_bg_color: COLORS['bg']

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Detalhe da nota"
            left_action_items: [["arrow-left", lambda x: root.voltar()]]

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: "16dp"
                spacing: "12dp"
                size_hint_y: None
                height: self.minimum_height

                MDTextField:
                    id: titulo_field
                    hint_text: "Título"

                MDTextField:
                    id: descricao_field
                    hint_text: "Descrição"
                    multiline: True

                MDTextField:
                    id: solucao_field
                    hint_text: "Solução"
                    multiline: True

                MDTextField:
                    id: categoria_field
                    hint_text: "Categoria"

                MDTextField:
                    id: tags_field
                    hint_text: "Tags (separadas por vírgula)"

                MDRaisedButton:
                    text: "SALVAR ALTERAÇÕES"
                    pos_hint: {"center_x": .5}
                    on_release: root.salvar_edicao()
