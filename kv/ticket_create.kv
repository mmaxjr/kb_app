#:import COLORS theme.COLORS

<TicketCreateScreen>:
    md_bg_color: COLORS['bg']

    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Nova nota"
            left_action_items: [["arrow-left", lambda x: root.cancelar()]]

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: "16dp"
                spacing: "12dp"
                size_hint_y: None
                height: self.minimum_height

                MDTextField:
                    id: titulo_field
                    hint_text: "Título"

                MDTextField:
                    id: descricao_field
                    hint_text: "Descrição"
                    multiline: True

                MDTextField:
                    id: solucao_field
                    hint_text: "Solução"
                    multiline: True

                MDTextField:
                    id: categoria_field
                    hint_text: "Categoria"

                MDTextField:
                    id: tags_field
                    hint_text: "Tags (separadas por vírgula)"

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: "48dp"
                    spacing: "8dp"

                    MDLabel:
                        text: "Salvar somente no dispositivo (não sincroniza com o Notion)"
                        color: COLORS['text_dim']
                        font_size: "13sp"

                    MDSwitch:
                        id: local_only_switch
                        pos_hint: {"center_y": .5}

                MDRaisedButton:
                    text: "CRIAR NOTA"
                    pos_hint: {"center_x": .5}
                    on_release: root.criar_ticket()
